[sub_resource type="Resource" id="Resource_nf104"]
script = ExtResource("4_50xk0")
lines = Array[String](["I had a name once. A number after... like you'll have. Now, mostly, I have inventory", "hey promise the fresh ones they'll go free when the war's won. I've outlasted three wars. Do the arithmetic.", "Buy, or don't. The dead aren't in a hurry."])
label_override = "Talk about yourself"
metadata/_custom_type_script = "uid://cb4eeew5u1da1"

[resource]
script = ExtResource("4_gsvox")
npc_id = 111
npc_name = "Bonecarver"
skin = ExtResource("5_rdenb")
greeting = "Don't flinch. You'll wear this face too, you keep dying like you mean it or like [i]they[/i] mean it. I went out past counting and came back... economical. Bone's honest, at least. Buy something."
interactions = Array[ExtResource("1_k0xw0")]([SubResource("Resource_twffw"), SubResource("Resource_nf104")])
metadata/_custom_type_script = "uid://ddps5vwhnf048"
