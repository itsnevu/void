[resource]
script = ExtResource("9_otpy6")
npc_id = 10
npc_name = "Foreman"
greeting = "If you're here to gawk, the quarry's that way and so's the gate. If you want honest coin, I've veins need clearing and not enough backs to do it. Pick up a pick."
