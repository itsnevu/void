[sub_resource type="Resource" id="Resource_0ftqf"]
script = ExtResource("4_35bs7")
lines = Array[String](["What's down there isn't beasts. It's less than that, shapes the dark throws off. Kill the big one and the rest go out like snuffed candles.", "Plenty go down. Most come up. 'Most' is carrying that sentence."])
label_override = "What's down there?"
metadata/_custom_type_script = "uid://cb4eeew5u1da1"

