description = "+20 max health while wielding a hammer."
branch = &"resolve"
tier = 2
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_hp_juggernaut")])

[sub_resource type="Resource" id="Mod_ms_momentum"]
script = ExtResource("3_mod")
stat_name = "move_speed"
value = 10.0

[sub_resource type="Resource" id="Node_momentum"]
script = ExtResource("2_node")
id = &"hammer_momentum"
node_name = "Momentum"
description = "+10 move speed while wielding a hammer. Shrug off its weight and keep advancing."
branch = &"inspiration"
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_ms_momentum")])

[sub_resource type="Resource" id="Node_aura1"]
script = ExtResource("2_node")
id = &"hammer_aura"
node_name = "Healing Aura"
description = "Plant your hammer and channel a healing aura, mending you and nearby allies over a few seconds. You're rooted while it holds, and moving cancels it. Mount it in a special slot."
branch = &"inspiration"
ability = ExtResource("7_aura1")

[sub_resource type="Resource" id="Node_aura2"]
script = ExtResource("2_node")
id = &"hammer_aura_2"
node_name = "Healing Aura II"
description = "A stronger, wider healing channel. Weight 2."
branch = &"inspiration"
tier = 2
ability = ExtResource("8_aura2")
upgrades = &"hammer_aura"

[sub_resource type="Resource" id="Node_aura3"]
script = ExtResource("2_node")
id = &"hammer_aura_3"
node_name = "Healing Aura III"
description = "The fullest sustain: a broad aura that heals you and your allies for a long, steady channel. Weight 3."
branch = &"inspiration"
tier = 3
ability = ExtResource("9_aura3")
upgrades = &"hammer_aura_2"

