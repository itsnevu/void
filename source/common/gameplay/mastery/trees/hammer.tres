[sub_resource type="Resource" id="Node_crush"]
script = ExtResource("2_node")
id = &"hammer_crush"
node_name = "Crushing Blow"
description = "A wind-up slam that hits everything around you for massive damage. Mount it in your hammer's special slot."
branch = &"domination"
ability = ExtResource("4_crush")

[sub_resource type="Resource" id="Node_shock"]
script = ExtResource("2_node")
id = &"hammer_shockwave"
node_name = "Shockwave"
description = "Slam the ground, damaging and slowing everyone around you for 1.5 seconds. Weight 2."
branch = &"domination"
tier = 2
ability = ExtResource("5_shock")
upgrades = &"hammer_crush"

[sub_resource type="Resource" id="Node_quake"]
script = ExtResource("2_node")
id = &"hammer_earthshatter"
node_name = "Earthshatter"
description = "A devastating overhead blow that shatters the ground, hitting and slowing all around. Weight 3."
branch = &"domination"
tier = 3
ability = ExtResource("6_quake")
upgrades = &"hammer_shockwave"

[sub_resource type="Resource" id="Mod_armor_bulwark"]
script = ExtResource("3_mod")
stat_name = "armor"
value = 6.0

[sub_resource type="Resource" id="Node_bulwark"]
script = ExtResource("2_node")
id = &"hammer_bulwark"
node_name = "Bulwark"
description = "+6 armor while wielding a hammer."
branch = &"resolve"
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_armor_bulwark")])

[sub_resource type="Resource" id="Mod_hp_juggernaut"]
script = ExtResource("3_mod")
