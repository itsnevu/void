[sub_resource type="Resource" id="Node_multishot"]
script = ExtResource("2_node")
id = &"bow_multishot"
node_name = "Multishot"
description = "Charge and loose a fan of three arrows. Mount it in your bow's special slot."
branch = &"domination"
ability = ExtResource("4_multi")

[sub_resource type="Resource" id="Node_venom"]
script = ExtResource("2_node")
id = &"bow_venom"
node_name = "Venom Shot"
description = "A charged shot that poisons the target, dealing damage over 4 seconds. Weight 2."
branch = &"domination"
tier = 2
ability = ExtResource("5_venom")
upgrades = &"bow_multishot"

[sub_resource type="Resource" id="Node_storm"]
script = ExtResource("2_node")
id = &"bow_arrowstorm"
node_name = "Arrow Storm"
description = "Charge and unleash a wide volley of seven arrows. Weight 3."
branch = &"domination"
tier = 3
ability = ExtResource("6_storm")
upgrades = &"bow_venom"

[sub_resource type="Resource" id="Mod_hp_survival"]
script = ExtResource("3_mod")
value = 12.0

[sub_resource type="Resource" id="Node_survival"]
script = ExtResource("2_node")
id = &"bow_survival"
node_name = "Survival Instinct"
description = "+12 max health while wielding a bow."
branch = &"resolve"
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_hp_survival")])

[sub_resource type="Resource" id="Mod_ms_lightstep"]
script = ExtResource("3_mod")
stat_name = "move_speed"
value = 6.0

[sub_resource type="Resource" id="Node_lightstep"]
script = ExtResource("2_node")
id = &"bow_lightstep"
node_name = "Light Step"
description = "+6 move speed while wielding a bow. Stay out of reach."
branch = &"inspiration"
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_ms_lightstep")])

[sub_resource type="Resource" id="Mod_haste_hawkeye"]
script = ExtResource("3_mod")
stat_name = "ability_haste"
value = 10.0

[sub_resource type="Resource" id="Node_hawkeye"]
script = ExtResource("2_node")
id = &"bow_hawkeye"
node_name = "Hawkeye"
description = "+10 ability haste while wielding a bow. Draw and fire faster."
branch = &"inspiration"
tier = 2
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_haste_hawkeye")])

[resource]
script = ExtResource("1_tree")
category = &"bow"
display_name = "Bow"
nodes = Array[ExtResource("2_node")]([SubResource("Node_multishot"), SubResource("Node_venom"), SubResource("Node_storm"), SubResource("Node_survival"), SubResource("Node_lightstep"), SubResource("Node_hawkeye")])
